doctype html
html(lang='en')
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Mongoose v#{package.version}: #{title}
    //- Inline script to prevent flash of wrong theme — must run before CSS loads
    script.
      (function() {
        var theme = localStorage.getItem('mongoose-theme');
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
        }
      })();
    include ./includes/favicon
    block style

      link(rel="stylesheet", href="https://fonts.googleapis.com/css?family=Open+Sans:wght@400;500;600;700&display=swap")
      link(rel="stylesheet", href=`${versions.versionedPath}/docs/css/mongoose9.css?v=${Date.now()}`)
      link(rel="stylesheet", href=`${versions.versionedPath}/docs/css/github.css?v=${Date.now()}`)
      link(rel="stylesheet", href=`${versions.versionedPath}/docs/css/carbonads.css`)
      link(rel="stylesheet", href=`${versions.versionedPath}/docs/css/copy-code.css`)

      meta(name='msapplication-TileColor', content='#ffffff')
      meta(name='msapplication-TileImage', content=`${versions.versionedPath}/docs/images/favicon/ms-icon-144x144.png`)
      meta(name='theme-color', content='#ffffff')

  body
    block layout
      - const docsHome = `${versions.versionedPath}/docs/index.html`
      - const apiHome = `${versions.versionedPath}/docs/api/mongoose.html`
      - const migrationHome = `${versions.versionedPath}/docs/migrating_to_9.html`
      - const faqHome = `${versions.versionedPath}/docs/faq.html`
      - const isApiPage = outputUrl.startsWith(`${versions.versionedPath}/docs/api/`)
      - const isMigrationPage = outputUrl === migrationHome
      - const isFaqPage = outputUrl === faqHome
      - const isDocsPage = !isApiPage && !isMigrationPage && !isFaqPage

      header.site-header
        .site-header-inner
          button.mobile-menu-toggle#menuLink(aria-label="Toggle navigation")
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>

          a.site-logo(href="/")
            .site-logo-inner
              span.site-logo-mark(role="img" aria-label="Mongoose logo")
              span.site-logo-text mongoose

          .site-search
            input#search-input-nav(type="text", placeholder="Search")
            button.site-search-button#search-button-nav(aria-label="Search")
              img(src=`${versions.versionedPath}/docs/images/search.svg`)

          nav.top-navbar(aria-label="Primary")
            a.top-navbar-link(href=docsHome, class=isDocsPage ? 'active' : '') Docs
            a.top-navbar-link(href=apiHome, class=isApiPage ? 'active' : '') API
            a.top-navbar-link(href=migrationHome, class=isMigrationPage ? 'active' : '') Migration
            a.top-navbar-link(href=faqHome, class=isFaqPage ? 'active' : '') FAQ

          .site-actions
            button.icon-button#theme-toggle-btn(aria-label="Toggle dark mode" title="Toggle dark/light theme")
              <svg id="theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              <svg id="theme-icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            a.icon-link(href="https://github.com/Automattic/mongoose", target="_blank", rel="noopener", aria-label="GitHub repository")
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.55v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.04 11.04 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.77.12 3.06.74.81 1.18 1.84 1.18 3.1 0 4.44-2.7 5.4-5.27 5.69.41.35.77 1.05.77 2.12v3.14c0 .31.2.66.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
            button.icon-button.mobile-toc-toggle#tocLink(aria-label="Toggle table of contents" aria-controls="toc-sidebar" title="Table of contents")
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M8 6h12M8 12h12M8 18h12"/><path d="M4 6h.01M4 12h.01M4 18h.01"/></svg>

      #layout.site-body
        aside.left-sidebar#menu
          - const pastVersionsHref = (p) => `/docs/${p}/index.html`

          .version-picker#version-picker
            .version-picker-label Version
            button.version-picker-button(type="button" aria-haspopup="true" aria-expanded="false")
              span.version-picker-current v#{versions.currentVersion.listed}
              <svg class="version-picker-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            ul.version-picker-menu(role="menu")
              - if (versions.currentVersion.listed !== versions.latestVersion.listed)
                li
                  a.version-picker-item(role="menuitem" href=`${versions.latestVersion.path}/docs/index.html`) v#{versions.latestVersion.listed} (latest)
              each pastVersion in versions.pastVersions
                li
                  a.version-picker-item(role="menuitem" href=pastVersionsHref(pastVersion.path)) v#{pastVersion.listed}

          nav.sidebar-nav(aria-label="Docs navigation")
            .sidebar-section
              h3.sidebar-section-title Getting Started
              ul.sidebar-list
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/index.html`, class=outputUrl === `${versions.versionedPath}/docs/index.html` ? 'active' : '') Quick Start
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/guides.html`, class=outputUrl === `${versions.versionedPath}/docs/guides.html` ? 'active' : '') All Guides

            .sidebar-section
              h3.sidebar-section-title Guides
              ul.sidebar-list
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/guide.html`, class=outputUrl === `${versions.versionedPath}/docs/guide.html` ? 'active' : '') Schemas
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/schematypes.html`, class=outputUrl === `${versions.versionedPath}/docs/schematypes.html` ? 'active' : '') SchemaTypes
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/connections.html`, class=outputUrl === `${versions.versionedPath}/docs/connections.html` ? 'active' : '') Connections
                  - if ([`${versions.versionedPath}/docs/connections`, `${versions.versionedPath}/docs/tutorials/ssl`].some(path => outputUrl.startsWith(path)))
                    ul.sidebar-children
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/tutorials/ssl.html`, class=outputUrl === `${versions.versionedPath}/docs/tutorials/ssl.html` ? 'active' : '') TLS/SSL Connections
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/models.html`, class=outputUrl === `${versions.versionedPath}/docs/models.html` ? 'active' : '') Models
                  - if ([`${versions.versionedPath}/docs/models`, `${versions.versionedPath}/docs/change-streams`].some(path => outputUrl.startsWith(path)))
                    ul.sidebar-children
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/change-streams.html`, class=outputUrl === `${versions.versionedPath}/docs/change-streams.html` ? 'active' : '') Change Streams
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/documents.html`, class=outputUrl === `${versions.versionedPath}/docs/documents.html` ? 'active' : '') Documents
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/subdocs.html`, class=outputUrl === `${versions.versionedPath}/docs/subdocs.html` ? 'active' : '') Subdocuments
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/queries.html`, class=outputUrl === `${versions.versionedPath}/docs/queries.html` ? 'active' : '') Queries
                  - if ([`${versions.versionedPath}/docs/queries`, `${versions.versionedPath}/docs/tutorials/findoneandupdate`, `${versions.versionedPath}/docs/tutorials/lean`, `${versions.versionedPath}/docs/tutorials/query_casting`].some(path => outputUrl.startsWith(path)))
                    ul.sidebar-children
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/tutorials/query_casting.html`, class=outputUrl === `${versions.versionedPath}/docs/tutorials/query_casting.html` ? 'active' : '') Query Casting
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/tutorials/findoneandupdate.html`, class=outputUrl === `${versions.versionedPath}/docs/tutorials/findoneandupdate.html` ? 'active' : '') findOneAndUpdate
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/tutorials/lean.html`, class=outputUrl === `${versions.versionedPath}/docs/tutorials/lean.html` ? 'active' : '') The Lean Option
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/validation.html`, class=outputUrl === `${versions.versionedPath}/docs/validation.html` ? 'active' : '') Validation
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/middleware.html`, class=outputUrl === `${versions.versionedPath}/docs/middleware.html` ? 'active' : '') Middleware
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/populate.html`, class=outputUrl === `${versions.versionedPath}/docs/populate.html` ? 'active' : '') Populate
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/discriminators.html`, class=outputUrl === `${versions.versionedPath}/docs/discriminators.html` ? 'active' : '') Discriminators
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/plugins.html`, class=outputUrl === `${versions.versionedPath}/docs/plugins.html` ? 'active' : '') Plugins
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/timestamps.html`, class=outputUrl === `${versions.versionedPath}/docs/timestamps.html` ? 'active' : '') Timestamps
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/transactions.html`, class=outputUrl === `${versions.versionedPath}/docs/transactions.html` ? 'active' : '') Transactions
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/typescript.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript.html` ? 'active' : '') TypeScript
                  - if (outputUrl.startsWith(`${versions.versionedPath}/docs/typescript`))
                    ul.sidebar-children
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/schemas.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/schemas.html` ? 'active' : '') Schemas
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/statics-and-methods.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/statics-and-methods.html` ? 'active' : '') Statics and Methods
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/queries.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/queries.html` ? 'active' : '') Queries
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/query-helpers.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/query-helpers.html` ? 'active' : '') Query Helpers
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/populate.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/populate.html` ? 'active' : '') Populate
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/virtuals.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/virtuals.html` ? 'active' : '') Virtuals
                      li.sidebar-item
                        a.sidebar-link(href=`${versions.versionedPath}/docs/typescript/subdocuments.html`, class=outputUrl === `${versions.versionedPath}/docs/typescript/subdocuments.html` ? 'active' : '') Subdocuments

            .sidebar-section
              h3.sidebar-section-title API Reference
              ul.sidebar-list
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/mongoose.html`, class=outputUrl === `${versions.versionedPath}/docs/api/mongoose.html` ? 'active' : '') Mongoose
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/schema.html`, class=outputUrl === `${versions.versionedPath}/docs/api/schema.html` ? 'active' : '') Schema
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/connection.html`, class=outputUrl === `${versions.versionedPath}/docs/api/connection.html` ? 'active' : '') Connection
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/document.html`, class=outputUrl === `${versions.versionedPath}/docs/api/document.html` ? 'active' : '') Document
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/model.html`, class=outputUrl === `${versions.versionedPath}/docs/api/model.html` ? 'active' : '') Model
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/query.html`, class=outputUrl === `${versions.versionedPath}/docs/api/query.html` ? 'active' : '') Query
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/aggregate.html`, class=outputUrl === `${versions.versionedPath}/docs/api/aggregate.html` ? 'active' : '') Aggregate
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/schematype.html`, class=outputUrl === `${versions.versionedPath}/docs/api/schematype.html` ? 'active' : '') SchemaType
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/api/virtualtype.html`, class=outputUrl === `${versions.versionedPath}/docs/api/virtualtype.html` ? 'active' : '') VirtualType

            .sidebar-section
              h3.sidebar-section-title Reference
              ul.sidebar-list
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/migrating_to_9.html`, class=outputUrl === `${versions.versionedPath}/docs/migrating_to_9.html` ? 'active' : '') Migration Guide
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/compatibility.html`, class=outputUrl === `${versions.versionedPath}/docs/compatibility.html` ? 'active' : '') Version Compatibility
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/version-support.html`, class=outputUrl === `${versions.versionedPath}/docs/version-support.html` ? 'active' : '') Version Support
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/faq.html`, class=outputUrl === `${versions.versionedPath}/docs/faq.html` ? 'active' : '') FAQ
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/further_reading.html`, class=outputUrl === `${versions.versionedPath}/docs/further_reading.html` ? 'active' : '') Further Reading

            .sidebar-section
              h3.sidebar-section-title Community
              ul.sidebar-list
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/enterprise.html`, class=outputUrl === `${versions.versionedPath}/docs/enterprise.html` ? 'active' : '') For Enterprise
                li.sidebar-item
                  a.sidebar-link(href=`${versions.versionedPath}/docs/sponsors.html`, class=outputUrl === `${versions.versionedPath}/docs/sponsors.html` ? 'active' : '') Sponsors

        main.site-main
          article.article#content
            block content

        aside.right-sidebar#toc-sidebar
          nav.toc#toc(aria-label="On this page")
            h2.toc-title On This Page
            ul.toc-list#toc-list

          .right-sidebar-aside
            .cpc-ad
              <script async type="text/javascript" src="//cdn.carbonads.com/carbon.js?zoneid=1673&serve=C6AILKT&placement=mongoosejscom" id="_carbonads_js"></script>

            - if (jobs && jobs.length && !outputUrl.startsWith(`${versions.versionedPath}/docs/jobs.html`))
              .jobs
                h3.jobs-title Jobs
                each job in jobs
                  a.job-listing(href=`${versions.versionedPath}/docs/jobs.html#` + job._id)
                    .company-logo
                      img(src=job.logo)
                    .job-meta
                      .company #{job.company}
                      .title #{job.title}
                      .location #{job.location}
                .jobs-view-more
                  a(href=`${versions.versionedPath}/docs/jobs.html`) View more jobs

      script(type="text/javascript" src=`${versions.versionedPath}/docs/js/navbar-search.js`)
      script(type="text/javascript" src=`${versions.versionedPath}/docs/js/mobile-navbar-toggle.js`)
      script(type="text/javascript" src=`${versions.versionedPath}/docs/js/theme-toggle.js`)
      script(type="text/javascript" src=`${versions.versionedPath}/docs/js/copy-code.js`)
      script(type="text/javascript" src=`${versions.versionedPath}/docs/js/version-picker.js`)
      script(type="text/javascript" src=`${versions.versionedPath}/docs/js/toc.js`)
