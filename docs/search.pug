extends layout

append style
  link(rel="stylesheet", href=`${versions.versionedPath}/docs/css/search.css?v=${Date.now()}`)

block content
  .search-page
    h1 Search
    p.search-page-intro Search across Mongoose guides, API docs, and migration notes.

    form.search-page-form#search-form(role="search")
      label.sr-only(for="search-input") Search docs
      input#search-input(type="search", placeholder="Search docs", autocomplete="off")
      button.search-page-button#search-button(type="submit") Search

    div.search-results#results(aria-live="polite")

    script(type="text/javascript" src=`${versions.versionedPath}/docs/js/search.js`)
